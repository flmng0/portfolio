{
	"$schema": "https://www.schemastore.org/prettierrc.json",
	"useTabs": true,
	"singleQuote": true,
	"semi": false,
	"htmlWhitespaceSensitivity": "ignore",
	"trailingComma": "none",
	"printWidth": 100,
	"plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		}
	],
	"tailwindStylesheet": "./src/routes/layout.css"
}
